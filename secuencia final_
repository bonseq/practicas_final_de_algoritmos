FUNCION PESO(CARACTER); ENTERO
	i:=0
	MIENTRAS i<28 O A[i]=V HACER
		i:=i+1
	FIN MIENTRAS
	SI i<28 entonces
		RESGUARDO_SALIDA:=i
	SINO
		W("SE ENCONTRO UN CARCATER DESCONOCIDO, NO IRA A LA SALIDA")
	FS
FIN FUNCION

FUNCION STP1(X:SECUENCIA DE ALFANUMERICOS, S: VENTADNA):SECUENCIA DE ENTEROS
MEINTRAS NFDS(SEC) ENTONCES 
	P:=PRIM
	MIENTRAS V <> ' ' HACER
		NUEVO (p)
    	*P.DATO:=PESO(V)
    	*P.PROX:=nil
	    SI Prim=nil ENTONCES
    	    PRIM=P
    	SINO
        	*a.PROX:=P
    	FIN SI
    	a:=p
		RESGUARDO_V:=V 
		AVZ(SEC,V)
	FIN MIENTRAS
	SI RESGUARDO_V EN VOCALES ENTONCES
		*A.DATO:=*A.DATO+RaizCuadrada(*A.DATO)
	SINO
		*A.DATO:=*A.DATO+Factorial(*A.DATO)
	FIN SINO 
	MIENTRAS P<> NIL HACER
		P:=PRIM
		S:=*P.DATO
		ESC(X.DATO)
		DISPONER(P)
	FIN MIENTRAS
FIN MIENTRAS
	
